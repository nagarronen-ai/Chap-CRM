# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth
JWT_SECRET=your-random-secret-string

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_MARKETING_KEY=your-sendgrid-marketing-key
SENDGRID_FROM_EMAIL=you@yourcompany.com
SENDGRID_FROM_NAME=Your Company
SENDGRID_WEBHOOK_KEY_MARKETING=your-webhook-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/google/callback

# App URLs
CLIENT_URL=http://localhost:3000
API_BASE_URL=http://localhost:5000/api

# OpenAI (Chap agent + meeting summaries)
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_KEY_BRAIN=your-openai-api-key

# Anthropic (Thoughts, Superbrain, Invoice Parser)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Recall.ai (meeting recording - optional)
RECALL_API_KEY=your-recall-api-key

# Slack (Chap bot - optional)
SLACK_BOT_TOKEN=your-slack-bot-token
SLACK_APP_TOKEN=your-slack-app-token
SLACK_ALERTS_CHANNEL=#general

# Calendly (optional)
CALENDLY_API_KEY=your-calendly-api-key
CALENDLY_WEBHOOK_SECRET=your-calendly-webhook-secret
